<!-- Adaptive icon foreground layer — a simple white "W" monogram, kept
     within the 66x66dp safe zone (x:21-87, y:21-87 on the 108x108 canvas)
     so it isn't clipped by the OS's icon mask shape (circle/squircle/etc). -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M26,30 L37,78 L54,42 L71,78 L82,30"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000" />
</vector>
