<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main app theme — plain WebView container, no native action bar
         (the app supplies its own header per screen via ui/shell). -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorPrimaryDark">@color/brand_primary</item>
        <item name="android:windowBackground">@color/brand_primary</item>
    </style>

    <!-- Launch/splash theme (Android <12): a solid brand-color background
         plus a centered vector mark, shown for launchShowDuration (see
         capacitor.config.json's SplashScreen block) before AppTheme takes
         over once the WebView is ready. -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:background">@drawable/splash_icon</item>
    </style>

</resources>
